	num_meshes: i32

class extern SceneView
	var main_camera_params: CameraParams
	var shadow_indices: i32[] # read-only
	var lights: YLight&[] # read-only
	var shadow_box_size: f32
	var surfel_buffer: owned[UniformBuffer]
	var num_surfels: i32
	var probe_cells: ivec3
	var probe_min: vec3
	var probe_max: vec3
	var ray_tracing_data: RayTracingData*
	var fog_enabled: bool
	var fog_density: f32
	var fog_color: Color
	func extern __init__()
	func extern __delete__()
