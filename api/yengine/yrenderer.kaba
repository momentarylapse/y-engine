# scene

class extern MeshEmitter extends Object as shared
	func extern __init__(ctx: Context&, name: string)
	func extern virtual mut prepare(params: RenderParams)
	func extern virtual mut emit(params: RenderParams, rvd: RenderViewData, shadow_pass: bool)
	var ctx: Context&


class extern CubeEmitter extends MeshEmitter
	func extern __init__(ctx: Context&)
	func extern set_cube(cube: Box)
	var material: owned![Material]
	var matrix: mat4


class extern SceneRenderer extends Renderer
	func extern mut __init__(ctx: Context&, type: i32, scene_view: SceneView&)
	func extern mut set_view(params: RenderParams, cam: CameraParams, proj=(nil as mat4*))
	func extern mut add_emitter(emitters: shared![MeshEmitter])

	var background_color: Color?


