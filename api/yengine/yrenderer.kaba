use os
use .gfx.*

let EXPORT_IMPORTS = true


enum extern LightType
	DIRECTIONAL
	POINT
	CONE
	AMBIENT


struct extern YLight
	func extern mut init(type: LightType, c: Color, theta: f32 = -1.0)
	func extern suggest_shadow_projection(cam: CameraParams, shadow_box_size: f32) -> mat4
	var type: LightType
	var pos: vec3
	var ang: Quaternion
	var color: Color
	var power: f32
	var theta: f32
	var harshness: f32
	var enabled: bool
	var allow_shadow: bool
	var user_shadow_control: bool
	var user_shadow_theta: f32
	var shadow_dist_min: f32
	var shadow_dist_max: f32


enum extern TransparencyMode
	NONE
	FUNCTIONS
	COLOR_KEY_HARD
	COLOR_KEY_SMOOTH

class extern Material
	var albedo: Color
	var roughness: f32
	var metal: f32
	var emission: Color
	var textures: shared![Texture][]
	var shader_data: Any
	var cast_shadow: bool
	struct extern Pass as @noauto
		shader_path: os.Path
		cull_mode: CullMode
		wire_mode: bool
		z_write, z_test: bool
		mode: TransparencyMode
		source: Alpha
		destination: Alpha
	var pass0: Pass
	struct extern Friction as @noauto
		sliding: f32
		_static: f32
		rolling: f32
		jump: f32
	var friction: Friction
	func extern mut __init__()
	func extern __delete__()
#	func extern mut add_uniform(name: string, p: float*, size: int)


struct extern CameraParams
	var pos: vec3
	var ang: Quaternion

	var fov: f32
	var min_depth, max_depth: f32
	func extern projection_matrix(aspect_ratio: f32) -> mat4
	func extern view_matrix() -> mat4


class extern TextureManager
#	func extern __init__(ctx: GfxContext, dir: os.Path[])
class extern ShaderManager
	var default_shader: string
#	func extern __init__(ctx: GfxContext, dir: os.Path[])
	func extern mut load_shader_module(filename: os.Path)
class extern MaterialManager
#	func extern __init__(tm: TextureManager, dir: os.Path[])


#---------------------------
# context

# "yrenderer.Context"
class extern Context as @noauto
	var context: GfxContext& # "ygfx.Context"
	var texture_manager: TextureManager*
	var shader_manager: ShaderManager*
	var material_manager: MaterialManager*
	var tex_white: shared![Texture]
	func extern create_managers(texture_dirs: os.Path[], shader_dirs: os.Path[], material_dirs: os.Path[])
	func extern load_material(path: os.Path) -> Material&
	func extern create_internal_material() -> Material&
	func extern load_texture(path: os.Path) -> shared![Texture]
	func extern load_shader(path: os.Path) -> shared![Shader]
	func extern create_shader(source: string) -> xfer[Shader]
	func extern load_surface_shader(path: os.Path, render_path: string, vertex_module: string, geometry_module: string) -> shared![Shader]
	func extern load_shader_module(path: os.Path)


func extern api_init_glfw(window: void*) -> xfer[Context] # p: GLFWwindow*
func extern api_init_xhui(p: void*) -> xfer[Context] # p: xhui.Painter*


struct extern RenderParams
	func extern __assign__(o: RenderParams)

class extern RenderData as @noauto
	func extern draw_triangles(params: RenderParams, vb: VertexBuffer&)

class extern RenderViewData
	func extern __init__(ctx: Context&)
	func extern set_view(params: RenderParams, cam: CameraParams, proj=(nil as mat4*))
	func extern get_shader(material: Material*, pass_no: i32, vertex_shader_module: string, geometry_shader_module="", tessellation_module="") -> Shader&
	func extern start(params: RenderParams, matrix: mat4, shader: Shader*, material: Material*, pass_no: i32, top: PrimitiveTopology, vb: VertexBuffer*) -> RenderData&

class extern LineHelper
	func extern mut __init__()
	func extern mut __delete__()
	func extern mut start_frame(ui_scale=1.0)
	func extern mut begin_draw(params: RenderParams, rvd: RenderViewData)
	func extern mut set_color(c: Color)
	func extern mut set_z(enabled: bool)
	func extern mut set_line_width(w: f32)
	func extern mut draw_lines(points: vec3[], contiguous=true)

func extern apply_shader_data(params: RenderParams, s: Shader*, shader_data: Any)


#---------------------------
# interfaces

class extern Renderer
	func extern mut add_child(r: Renderer&)
	func extern virtual mut __delete__()
	func extern virtual mut prepare(params: RenderParams)
	func extern virtual mut draw(params: RenderParams)


class extern RenderTask extends Renderer
	var active: bool
	func virtual render(params: RenderParams)


class extern ComputeTask extends RenderTask
	nx: i32
	ny: i32
	nz: i32
	shader_data: Any
	func extern __init__(ctx: Context&, name: string, shader: shared![Shader], n: i32[])
	func override extern render(params: RenderParams)
	func extern bind_texture(index: i32, tex: Texture&)
	func extern bind_image(index: i32, tex: Texture&)
	func extern bind_uniform_buffer(index: i32, buf: UniformBuffer&)
	func extern bind_storage_buffer(index: i32, buf: ShaderStorageBuffer&)


